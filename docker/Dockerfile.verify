FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="/root/.elan/bin:${PATH}"

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    libgomp1 \
    libgmp-dev \
    python3 \
    python3-pip \
    python3-venv \
    tar \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install Lean via elan. The repo's lean-toolchain controls the version used
# by Lake.
RUN curl -sSf https://raw.githubusercontent.com/leanprover/elan/master/elan-init.sh \
    | sh -s -- -y --default-toolchain none

WORKDIR /app

# Lean toolchain + Lake project prebuild. `lake exe cache get` downloads
# precompiled Mathlib oleans from the leanprover-community reservoir (~3 min
# download vs ~30 min Mathlib build from source). `lake build` then elaborates
# the MathFin library + its direct deps (BrownianMotion etc.). This bakes
# the olean tree into the image at /app/.lake/, so the first verify call no
# longer pays for a cold Lake build.
COPY lakefile.lean lean-toolchain lake-manifest.json MathFin.lean ./
COPY MathFin/ MathFin/
RUN elan toolchain install "$(cat lean-toolchain)" \
    && lean --version \
    && lake --version \
    && lake exe cache get \
    && lake build

# Runtime defaults. Keep after the Lean prebuild layer so changing runtime
# caps does not invalidate the expensive build above.
RUN elan default "$(cat lean-toolchain)"

# Python deps last so editing pyproject.toml / tools/ does NOT invalidate the
# Lean prebuild layer above. The `[dev]` extra brings pytest + pytest-asyncio
# so the static lints (`pytest tests/test_router.py`,
# `python -m tools.verify.coverage_report`) run inside this container too.
COPY pyproject.toml requirements.txt ./
COPY tools/ tools/
RUN python3 -m pip install --break-system-packages -e ".[all,dev]"

COPY benchmarks/ benchmarks/
COPY mathfin.toml ./

ENTRYPOINT ["python3", "-m", "tools.verify"]
