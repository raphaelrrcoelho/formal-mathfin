@[reducible] def nullsAlg (m0 : MeasurableSpace ő©) (őľ : Measure ő©) : MeasurableSpace ő© :=
  MeasurableSpace.generateFrom {s | MeasurableSet[m0] s ‚ąß őľ s = 0}

lemma nullsAlg_le : nullsAlg m0 őľ ‚Č§ m0 :=
  MeasurableSpace.generateFrom_le fun _ hs => hs.1

/-- **The measure-theoretic crux.** Every set measurable for the null-augmented
ŌÉ-algebra `m‚āĀ ‚äĒ ūĚďĚ` is `őľ`-a.e. equal to an `m‚āĀ`-measurable set. Proof: the
collection of sets that are `=ŠĶź` an `m‚āĀ`-set is itself a ŌÉ-algebra (closed under
complement and countable union for `=ŠĶź`) containing both `m‚āĀ` (reflexivity) and
the generators of `ūĚďĚ` (a null set is `=ŠĶź ‚ąÖ`); being an upper bound of both, it
contains their supremum. -/
theorem exists_ae_eq_of_sup_nulls {m‚āĀ : MeasurableSpace ő©}
    {s : Set ő©} (hs : MeasurableSet[m‚āĀ ‚äĒ nullsAlg m0 őľ] s) :
    ‚ąÉ t, MeasurableSet[m‚āĀ] t ‚ąß s =ŠĶź[őľ] t := by
  -- the collection, packaged as a `MeasurableSpace`
  let M : MeasurableSpace ő© :=
  { MeasurableSet' := fun s => ‚ąÉ t, MeasurableSet[m‚āĀ] t ‚ąß s =ŠĶź[őľ] t
    measurableSet_empty := ‚ü®‚ąÖ, m‚āĀ.measurableSet_empty, ae_eq_refl _‚ü©
    measurableSet_compl := fun s ‚ü®t, ht, hst‚ü© =>
      ‚ü®tŠ∂ú, ht.compl, (ae_eq_set_compl_compl (őľ := őľ)).mpr hst‚ü©
    measurableSet_iUnion := fun f hf => by
      choose t ht hft using hf
      refine ‚ü®‚čÉ n, t n, MeasurableSet.iUnion ht, ?_‚ü©
      simpa only [Set.biUnion_univ] using
        ae_eq_set_biUnion (őľ := őľ) Set.countable_univ (fun n (_ : n ‚ąą Set.univ) => hft n) }
  have hm‚āĀM : m‚āĀ ‚Č§ M := fun s hs => ‚ü®s, hs, ae_eq_refl _‚ü©
  have hnM : nullsAlg m0 őľ ‚Č§ M := by
    refine MeasurableSpace.generateFrom_le fun u hu => ‚ü®‚ąÖ, m‚āĀ.measurableSet_empty, ?_‚ü©
    rw [ae_eq_set]
    exact ‚ü®by simpa using hu.2, by simp‚ü©
  exact (sup_le hm‚āĀM hnM) s hs

/-- **Cond-expectation invariance under the null augmentation.** Conditioning on
the null-augmented ŌÉ-algebra `m‚āĀ ‚äĒ ūĚďĚ` agrees `őľ`-a.e. with conditioning on `m‚āĀ`:
the extra information is only null sets, which carry no information. Proof:
`őľ[f | m‚āĀ]` is `m‚āĀ`-measurable (hence `(m‚āĀ ‚äĒ ūĚďĚ)`-measurable) and satisfies the
`(m‚āĀ ‚äĒ ūĚďĚ)`-set-integral characterisation of the conditional expectation, because
every `(m‚āĀ ‚äĒ ūĚďĚ)`-set is `=ŠĶź` an `m‚āĀ`-set (`exists_ae_eq_of_sup_nulls`) over which
the `m‚āĀ`-characterisation already holds. -/
theorem condExp_sup_nulls [IsFiniteMeasure őľ] {m‚āĀ : MeasurableSpace ő©} (hm‚āĀ : m‚āĀ ‚Č§ m0)
    {f : ő© ‚Üí ‚ĄĚ} (hf : Integrable f őľ) :
    őľ[f | m‚āĀ ‚äĒ nullsAlg m0 őľ] =ŠĶź[őľ] őľ[f | m‚āĀ] := by
  have hm : m‚āĀ ‚äĒ nullsAlg m0 őľ ‚Č§ m0 := sup_le hm‚āĀ nullsAlg_le
  haveI : SigmaFinite (őľ.trim hm‚āĀ) := (isFiniteMeasure_trim hm‚āĀ).toSigmaFinite
  haveI : SigmaFinite (őľ.trim hm) := (isFiniteMeasure_trim hm).toSigmaFinite
  refine (ae_eq_condExp_of_forall_setIntegral_eq hm hf
    (fun s _ _ => integrable_condExp.integrableOn) (fun s hs _ => ?_)
    ((stronglyMeasurable_condExp.mono le_sup_left).aestronglyMeasurable)).symm
  obtain ‚ü®t, htm, hst‚ü© := exists_ae_eq_of_sup_nulls hs
  rw [setIntegral_congr_set hst, setIntegral_condExp hm‚āĀ hf htm]
  exact (setIntegral_congr_set hst).symm

